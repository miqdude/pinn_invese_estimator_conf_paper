
@inproceedings{tan_cooperative_2018,
	address = {Anchorage, AK},
	title = {Cooperative {Heavy} {Lifting} {Using} {Unmanned} {Multi}-{Agent} {Systems}},
	isbn = {978-1-5386-6089-8},
	url = {https://ieeexplore.ieee.org/document/8444215/},
	doi = {10.1109/ICCA.2018.8444215},
	abstract = {Cooperative load carrying is an area of multi-agent systems that has extensive potential applications. Though most of the complexities involved with multi-agent operations have been investigated in general swarm operations, the greatest challenge of heavy duty aerial transportation that has yet to be addressed is the limited control authority of the system as a whole as each individual agent, and hence effector, is typically signiﬁcantly smaller than the payload. Based on the conﬁguration whereby the vehicles are connected rigidly to the load, we present a general optimisation method to ﬁnd the most effective team arrangement that will maximise the control authority within the physical constraints of the system. Additionally, each UAV is allowed to tilt laterally at a ﬁxed angle relative to the payload, which provides a larger maximum rotational acceleration achievable about the yaw axis. The optimised solution, implementation and results based on the cooperative carrying task in the 2017 International Micro Air Vehicles Competition is presented in this paper. Testing results show that the system designed is effective in transporting the payload autonomously according to generated trajectories.},
	language = {en},
	urldate = {2025-10-01},
	booktitle = {2018 {IEEE} 14th {International} {Conference} on {Control} and {Automation} ({ICCA})},
	publisher = {IEEE},
	author = {Tan, Yu Herng and Lai, Shupeng and Wang, Kangli and Chen, Ben M.},
	month = jun,
	year = {2018},
	pages = {1119--1126},
	file = {PDF:C\:\\Users\\miqda\\Zotero\\storage\\KSXU6L4P\\Tan et al. - 2018 - Cooperative Heavy Lifting Using Unmanned Multi-Agent Systems.pdf:application/pdf},
}

